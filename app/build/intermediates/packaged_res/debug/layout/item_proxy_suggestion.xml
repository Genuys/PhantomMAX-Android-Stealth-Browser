<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_edit_text"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvProxyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Proxy Server"
        android:textColor="@color/phantom_text"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvProxyHost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="host:port"
            android:textColor="@color/phantom_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvProxyPing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--- ms"
            android:textColor="@color/phantom_accent"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
